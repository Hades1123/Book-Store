# Application
PORT=8080
API_PREFIX=api
NODE_ENV='development'

# Database
DATABASE_URL="postgresql://DATABASE_NAME:DATABASE_PASSWORD@localhost:5432/?schema=main"
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_SYNCHRONIZE=true

# Gmail app password
GMAIL_APP_PASS=your_app_pass
GMAIL_USER_NAME=your_gmail

# JWT
JWT_ACCESS_SECRET=your_screte_code
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_secrete_code
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_API_SECRET=your_cloudinary_code
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=

# FE Url
FE_URL=http://localhost:5173