enum PaymentMethod {
  COD
  VNPAY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Payment {
  id String @id @default(uuid())
  method PaymentMethod
  status PaymentStatus @default(PENDING)
  transactionId String?
  amount BigInt
  paidAt DateTime?
  createdAt DateTime @default(now())

  // relation
  orderId String
  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}