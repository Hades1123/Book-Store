model Address{
    id String @id @default(uuid())
    receiverName String
    phone String 
    province String
    ward String 
    detailAddress String 
    isDefault Boolean
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // relation
    userId String
    user User @relation(fields: [userId], references: [id])

    @@map("addresses")
}